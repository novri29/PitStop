<?xml version="1.0" encoding="utf-8"?>
<!--
  Form untuk menambahkan barang baru ke Stok Barang:
  - Foto produk (tap kotak abu-abu untuk pilih dari galeri)
  - Nama Barang
  - Kategori (dropdown: Perawatan / Interior / Alat / Lainnya)
  - Stok Awal
  - Harga
  Warna header (#2F6BFF) dan tombol disamakan dengan tampilan Stok Barang.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA"
    tools:context="com.pitstop.ui.admin.adminfragment.TambahBarangFragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A2D80"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Tambah Barang"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Foto produk -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFoto"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#EDEFF5"
                app:strokeColor="#DADFEA"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/ivFotoProduk"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:scaleType="centerCrop"
                        app:tint="#8A93A6"
                        android:contentDescription="Foto produk" />

                    <TextView
                        android:id="@+id/tvFotoHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ketuk untuk tambah foto produk"
                        android:textColor="#8A93A6"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nama Barang -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNamaBarang"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="Nama Barang">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNamaBarang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Kategori (dropdown) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilKategori"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Kategori">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/actvKategori"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Stok -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStok"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Stok Awal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Harga -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHarga"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Harga (Rp)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Simpan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Simpan Barang"
                android:textAllCaps="false"
                app:cornerRadius="12dp"
                app:backgroundTint="#0A2D80" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
